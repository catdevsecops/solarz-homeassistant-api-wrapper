// DEPENDENCY INJECTION
✅ PADRÃO:
type ServerConfig struct {
    Addr    string
    Handler http.Handler
}

func startServer(config ServerConfig) error {
    server := &http.Server{
        Addr:    config.Addr,
        Handler: config.Handler,
    }
    return server.ListenAndServe()
}

// KEY POINTS:
// 1. Usar struct para agrupar configurações
// 2. Passar como parâmetro, não usar globais
// 3. Facilita testes
// 4. Facilita reuso

// FACTORY PATTERN
✅ PADRÃO:
func setupRouter() *http.ServeMux {
    router := http.NewServeMux()
    router.HandleFunc("GET /api/v1/data", handler.GetData)
    router.HandleFunc("GET /health", healthHandler)
    return router
}

// KEY POINTS:
// 1. Função que retorna objeto configurado
// 2. Encapsula lógica de criação
// 3. Facilita testes
// 4. Facilita modificações futuras

